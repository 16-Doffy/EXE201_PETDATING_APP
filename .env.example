# Admin API configuration
# Local development
# EXPO_PUBLIC_ADMIN_API_URL=http://localhost:8080

# Production / deployed backend
# Set this in the Vercel project environment variables used at build time.
# This must point to the deployed Spring Boot admin API host, not the static frontend Vercel URL unless you add a same-origin /api proxy.
EXPO_PUBLIC_ADMIN_API_URL=https://your-admin-api.example.com
